# .env.example
# Copy this to .env and fill in your real values
# NEVER commit .env — only .env.example goes to git

# AWS Credentials
# Use IAM role in production. For local dev use access keys.
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=ap-south-1

# DynamoDB Table Names
DYNAMO_STREAM_TABLE=costintel-live-stream
DYNAMO_AUDIT_TABLE=costintel-audit-log
DYNAMO_APPROVAL_TABLE=costintel-approvals

# These are read by Next.js API routes server-side (no NEXT_PUBLIC_ prefix needed)
# If you need them client-side, prefix with NEXT_PUBLIC_

# Simulation Settings
SIMULATION_INTERVAL_MS=8000
DEFAULT_WINDOW_MINUTES=30
